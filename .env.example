# OpenAI API Key (Required for generation)
# Use 'mock' to run without API credits (generates dummy content)
OPENAI_API_KEY="your-openai-api-key-here"
OPENAI_MODEL="gpt-3.5-turbo"

# API Keys for External Services
UNSPLASH_API_APP_ID="your-unsplash-app-id-here"
UNSPLASH_ACCESS_KEY="your-unsplash-access-key-here"
UNSPLASH_API_SECRET="your-unsplash-api-secret-here"
# Pexels Video/Image Search API
PEXELS_API_KEY="your-pexels-api-key-here"
# Pixabay Video/Image Search API
PIXABAY_API_KEY="your-pixabay-api-key-here"
# SerpAPI for Google/Bing search
SERPAPI_API_KEY="your-serpapi-key-here"

# ====================
# PROXY SETTINGS
# ====================
# Para ambientes com proxy corporativo que bloqueia APIs externas
USE_PROXY=false
PROXY_TYPE=socks5  # Opções: socks5, http, https, none
PROXY_HOST=localhost
PROXY_PORT=1080
PROXY_USERNAME=  # Opcional - Usuário para autenticação do proxy
PROXY_PASSWORD=  # Opcional - Senha para autenticação do proxy
NO_PROXY_DOMAINS=localhost,127.0.0.1  # Domínios que não devem usar proxy
VERIFY_SSL=true  # Definir como false apenas em último caso (inseguro)

# Prompts
PROMPT_INIT_TEMPLATE="Tópico: {topic}\nDuração Total mínima: {duration} minutos, considere que cada palavra leva em média 0,4 segundo para ser lida.\n\nPrimeiro, defina o Estilo Visual e os Personagens.\n\nSchema JSON:\n{{ 'visual_style': 'string', 'characters': [ {{ 'name': 'string', 'physical_description': 'string', 'voice_type': 'string' }} ] }}"
PROMPT_CHAPTERS_TEMPLATE="Agora, liste todos os capítulos para cobrir toda a duração.\n\nSchema JSON:\n{{ 'chapters': [ {{ 'order': int, 'title': 'string', 'estimated_duration_minutes': float, 'description': 'string' }} ] }}"
PROMPT_SUBCHAPTERS_TEMPLATE="Para o Capítulo {chapter_order} '{chapter_title}', faça a quebra em Sub-capítulos.\n\nSchema JSON:\n{{ 'subchapters': [ {{ 'order': int, 'title': 'string', 'description': 'string' }} ] }}"
PROMPT_SCENES_TEMPLATE="Para o Sub-capítulo '{subchapter_title}', gere Cenas ricas/detalhadas.\n\nInclua: duração, narração, nome_personagem (da nossa lista), tipo_voz, descrição_visual, prompt_imagem (para IA), prompt_video (vídeo IA 10s), prompt_audio (sfx).\n\nSchema JSON:\n{{ 'scenes': [ {{ 'id': int, 'order': int, 'duration_seconds': int, 'narration_content': 'string', 'character_name': 'string', 'voice_type': 'string', 'visual_description': 'string', 'image_prompt': 'string', 'video_prompt': 'string', 'audio_prompt': 'string' }} ] }}"
